# Next.js tự đọc .env / .env.local khi chạy `next dev` và `next build` — không cần cài hay import `dotenv`.
# Sửa biến xong phải restart dev server. NEXT_PUBLIC_* được embed vào bundle client lúc build.

# Backend API origin (no trailing slash)
NEXT_PUBLIC_HOST_API_URL=http://103.159.51.19:5294

# Root domain for multi-tenant routing.
# - Local: lvh.me (use id.lvh.me, lms-admin.lvh.me, stem.lvh.me, ...)
#   lvh.me resolves to 127.0.0.1 and supports cookie sharing across subdomains.
# - Test/Live: daihoc.io.vn
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me

# Fixed portals
NEXT_PUBLIC_LOGIN_DOMAIN=http://id.lvh.me:8081
NEXT_PUBLIC_ADMIN_DOMAIN=http://lms-admin.lvh.me:8081

# Optional local override used by domain routing utility.
# Port must match PORT in package.json scripts (default 8081).
NEXT_PUBLIC_LOCAL_ROOT_HOST=lvh.me
NEXT_PUBLIC_LOCAL_PORT=8081
