# ============================================================
# Frontend Environment Configuration
# ============================================================

# Deployment environment: development, staging, production
ENVIRONMENT=production

# Application
APP_NAME=lms-web
APP_PORT=3000
APP_VERSION=1.0.0

# Node environment
NODE_ENV=production

# API Configuration (must match next.config.js)
API_URL=
HOST_API_URL=
NEXT_PUBLIC_HOST_API_URL=https://dev-api.daihoc.io.vn

# Domain Configuration
# Root domain - used to build tenant subdomains (e.g. stem.daihoc.io.vn)
NEXT_PUBLIC_ROOT_DOMAIN=daihoc.io.vn
# Login page domain - where unauthenticated users land
NEXT_PUBLIC_LOGIN_DOMAIN=https://id.daihoc.io.vn
# Admin dashboard domain - for SUPER_ADMIN / TENANT_ADMIN after login
NEXT_PUBLIC_ADMIN_DOMAIN=https://lms-admin.daihoc.io.vn

# Auth Configuration
NEXT_PUBLIC_AUTH0_DOMAIN=your-auth0-domain
NEXT_PUBLIC_AUTH0_CLIENT_ID=your-auth0-client-id
NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://your-domain.com/api/auth/callback

# Image optimization
NEXT_PUBLIC_IMAGE_DOMAIN=your-domain.com

# Analytics & Monitoring (optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SENTRY=false

# Docker related
CONTAINER_NAME=lms-web
IMAGE_NAME=lms-web:latest
IMAGE_REGISTRY=

# Timezone
TZ=Asia/Ho_Chi_Minh
