{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "aig-lms",
    "Audience": "aig-lms-clients",
    "ExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 1
  },
  "Tenancy": {
    "AdminSubdomain": "lms-admin",
    "AdminDomains": ["id.daihoc.io.vn", "lms-admin.daihoc.io.vn"],
    "TenantBaseDomains": ["daihoc.io.vn"],
    "LocalHosts": ["localhost", "127.0.0.1", "::1"]
  },
  "MediaProcessing": {
    "FfmpegBinaryPath": "ffmpeg",
    "HlsSegmentDurationSeconds": 6,
    "PresignedGetTtlSeconds": 1800,
    "PresignedPutTtlSeconds": 1800,
    "RedisConnection": "localhost:6379",
    "RedisQueueKey": "lms:media:video:transcode",
    "RedisPollDelayMilliseconds": 500,
    "MaxRetryAttempts": 3,
    "RetryDelaySeconds": 5
  }
}
