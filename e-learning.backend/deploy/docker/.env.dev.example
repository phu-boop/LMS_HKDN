# === Dev Server Environment ===
# Copy this file to .env.dev and fill in values

# Database used by API container
# If PostgreSQL runs on the server host, keep host.docker.internal and the host port.
# If PostgreSQL runs in another Docker network/container, adjust DB_HOST/DB_PORT accordingly.
DB_HOST=host.docker.internal
DB_PORT=5434
DB_NAME=lms_dev
DB_USER=lms_dev
DB_PASSWORD=YOUR_DB_PASSWORD_HERE

# PostgreSQL container name used by deploy scripts for docker exec migrations
DB_CONTAINER=n8n-postgres-1

# Redis OSS 7.2.x (published for external access)
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_generate_strong_password

# JWT - generate a strong key: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_base64_48

# CORS origins (frontend URLs)
CORS_ORIGIN_1=http://103.159.51.19:3000
CORS_ORIGIN_2=http://103.159.51.19:5173

# Tenant/domain resolution on dev server
TENANCY_ADMIN_SUBDOMAIN=admin
TENANCY_ADMIN_DOMAIN_1=id.daihoc.io.vn
TENANCY_ADMIN_DOMAIN_2=admin.daihoc.io.vn
TENANCY_BASE_DOMAIN_1=daihoc.io.vn

# ── Object Storage (MinIO / S3) ──────────────────────────────────────────────
# Run setup-minio.sh once to create the service account — it will print these values.
ObjectStorage__Endpoint=https://media.daihoc.io.vn
ObjectStorage__UseSSL=true
ObjectStorage__AccessKey=lms-api-sa
ObjectStorage__SecretKey=CHANGE_ME_output_of_setup_minio_sh
ObjectStorage__ContentBucket=lms-content
ObjectStorage__HlsBucket=lms-hls
ObjectStorage__ThumbBucket=lms-thumb
# Presigned URL TTLs (seconds)
ObjectStorage__StreamUrlTtlSeconds=3600
ObjectStorage__ViewUrlTtlSeconds=3600
ObjectStorage__DownloadUrlTtlSeconds=300
