# === MinIO Object Storage - Dev Server ===
# Copy to .env.minio and fill in values
# Usage: docker compose -f deploy/docker/docker-compose.minio.yml --env-file deploy/docker/.env.minio up -d

# MinIO credentials
# Generate strong password: openssl rand -base64 24
MINIO_ROOT_USER=lms_minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_24

# External URL that MinIO embeds in presigned URLs.
# Must match what clients can reach (domain or IP+port).
# On dev server: use the media subdomain proxied by Nginx.
MINIO_SERVER_URL=https://media.daihoc.io.vn
MINIO_CONSOLE_URL=https://minio-console.daihoc.io.vn

# Host ports MinIO listens on (change if port conflicts exist)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
